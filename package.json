{
  "name": "hsk-master-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "HSK Master frontend — Next.js (App Router) app for Vietnamese learners of Chinese. Consumes the behsk backend API.",
  "scripts": {
    "dev": "next dev",
    "dev:clean": "npm run clean && next dev",
