# =============================================================================
# HSK Master Frontend — Environment
# =============================================================================
# The frontend proxies API calls to the backend (behsk) through Next.js route
# handlers, so the browser only ever talks to same-origin /api/* (no CORS).
#
# BACKEND_URL is used server-side by those proxy routes.
# -----------------------------------------------------------------------------

BACKEND_URL="http://localhost:4000"

# Optional: expose to the browser if you ever want to call the backend directly.
# NEXT_PUBLIC_BACKEND_URL="http://localhost:4000"
